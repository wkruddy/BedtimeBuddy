# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql+psycopg2://bedtimebuddy:bedtimebuddy@localhost:5432/bedtimebuddy

# Slack (socket mode) — optional for CLI-only local dev
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Ollama LLM
OLLAMA_BASE_URL=http://ai.homelab.internal:11434
OLLAMA_MODEL=qwen3.6:35b

# Optional web search for Story Generation research skill
# Leave unset to use graceful stub responses
WEB_SEARCH_URL=

# Path to SOUL files (default: ./souls relative to project root)
SOULS_DIR=souls
